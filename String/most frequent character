char getMaxOccuringChar(char* str) {
    
    
    int arr[26] = {0};
    
    for(int i = 0;  str[i] != '\0' ; i++)
    {
        char ch = str[i];
        
        int number = ch - 'a';
        
        arr[number]  ++;
    }
    
    int maxi = -1;
    int ans = 0;
    
    for(int i = 0; i<26; i++)
    {
        if(arr[i] > maxi)
        {
            maxi = arr[i];
            ans = i;
        }
        
        
    }
    
    return ans + 'a';
}
