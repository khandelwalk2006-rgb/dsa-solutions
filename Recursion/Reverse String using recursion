#include <bits/stdc++.h> 

void reverse(string &str , int start , int end)
{
    // base case
    if(start > end)
    {
        return;
    }

    swap(str[start] , str[end]);
    start ++;
    end --;

    reverse(str,start, end);

}
string reverseString(string str)
{
    reverse(str, 0 , str.length() - 1);

    return str;
	
}
