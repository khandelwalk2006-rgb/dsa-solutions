#include <bits/stdc++.h> 

void selectionSort(vector<int>& arr, int n , int i)
{
    // base case
    if(i >= n)
    {
        return ;
    }

    int minIndex = i;

    for(int j = i+1; j < n; j++)
    {
        if(arr[minIndex] > arr[j])
        {
            minIndex = j;
        }
    }

    swap(arr[minIndex] , arr[i]);

    // recursive call
    selectionSort(arr, n, i+1);
}


void selectionSort(vector<int>& arr, int n)
{   

    selectionSort(arr, n , 0);
    
}
