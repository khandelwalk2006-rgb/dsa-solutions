#include<iostream>
using namespace  std;

int sumArray(int arr[] , int size)
{
    // base case
    if(size == 0)
    {
        return 0;
    }

    if(size == 1)
    {
        return arr[0];
    }

    // recustive relation

    int ans = arr[0] + sumArray(arr + 1, size - 1);
    return ans;
}


int main()
{
    int arr[] = {1,0,3,4,5};
    int size = 5;

    int ans = sumArray(arr, size);

    cout << "sum of the array is " << ans << endl;
}
