#include <bits/stdc++.h> 

void insertionSort(vector<int> &arr , int n , int i)
{
    // base case 
    if(i >= n)
    {
        return ;
    }

    int temp = arr[i];
    int j = i-1;

    while(j >= 0 && arr[j] > temp)
    {
        arr[j+1] = arr[j];
        j--;
    }

    arr[j+1] = temp;


    // recursive call
    insertionSort(arr, n,i + 1);
}

void insertionSort(int n, vector<int> &arr)
{

    insertionSort(arr, n , 1);

    
}
