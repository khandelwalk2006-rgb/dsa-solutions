bool isPossible(vector<int> &boards, int k, long long mid)
{
    int painter = 1;
    long long int boardSum = 0;

    for(int i = 0; i<boards.size(); i++)
    {
        if(boardSum + boards[i] <= mid)
        {
            boardSum += boards[i];
        }

        else
        {
             painter ++;
         

         if(painter > k || boards[i] > mid)
         {
             return false;
         }

         boardSum = boards[i];
        }
    }

    return true;
}


int findLargestMinDistance(vector<int> &boards, int k)
{
   long long int sum = 0;

   for(int i = 0; i<boards.size() ; i++)
   {
       sum += boards[i];
   }


    long long int start  = 0; 
    long long int end = sum;
    long long int ans = -1;

    while(start <= end)
    {
        long long int mid = start + (end - start) /2 ;

        if(isPossible(boards,k,mid))
        {
            ans = mid;
            end = mid - 1;
        }

        else
        {
            start = mid + 1;
        }
    }

    return ans;


}
