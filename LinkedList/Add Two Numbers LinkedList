class Solution {
    
    private:
    Node* reverse(Node* head)
    {
        Node* curr = head;
        Node* prev = NULL;
        Node* forward = NULL;
        
        
        
        while(curr != NULL)
        {
            forward = curr -> next;
            curr -> next = prev;
            prev = curr;
            curr = forward;
        }
        
        return prev;
    }
    
    Node* removeLeadingZeroes(Node* head)
    {
        while(head != NULL && head -> data == 0)
        {
            head = head -> next;
        }
        
        if(head == NULL)
        {
            return new Node(0);
            
        }
        
        return head;
        
    }
    
    void insertAtTail(Node* &head , Node* &tail , int data)
    {
        Node* temp = new Node(data);
        
        if(head == NULL)
        {
            head = temp;
            tail = temp;
        }
        
        else
        {
            tail -> next = temp;
            tail = temp;
        }
    }
    
    Node* add(Node* head1 , Node* head2)
    {
        int carry = 0;
        
        Node* ansHead = NULL;
        Node* ansTail = NULL;
        
        while(head1 != NULL || head2 != NULL || carry)
        {
            int sum = carry;
            
            if(head1 != NULL)
            {
                sum += head1 -> data;
                head1 = head1 -> next;
            }
            
            if(head2 != NULL)
            {
                sum += head2 -> data;
                head2 = head2 -> next;
            }
            
            int digit = sum %10;
            carry = sum / 10;
            
            insertAtTail(ansHead , ansTail , digit);
        }
        
        return ansHead;
    }
  public:
    Node* addTwoLists(Node* head1, Node* head2) {
        
        head1 = removeLeadingZeroes(head1);
        head2 = removeLeadingZeroes(head2);
        
        head1 = reverse(head1);
        head2 = reverse(head2);
        
        Node* ans = add(head1 , head2);
        
        ans = reverse(ans);
        
        ans = removeLeadingZeroes(ans);
        
        
        return ans;
      
        
    }
};
