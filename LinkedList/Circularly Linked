bool isCircular(Node* head){
   
   if(head == NULL)
       return true;

   Node* slow = head;
   Node* fast = head;

   while(fast != NULL && fast->next != NULL)
   {
       slow = slow->next;
       fast = fast->next->next;

       if(slow == fast)
       {
           Node* temp = slow;

           do{
               if(temp == head)
                   return true;

               temp = temp->next;
           }while(temp != slow);

           return false;
       }
   }

   return false;
}
